FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY dashboard.go .
RUN CGO_ENABLED=0 GOOS=linux go build -o dashboard dashboard.go

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /root/

COPY --from=builder /app/dashboard .

EXPOSE 8080
CMD ["./dashboard"]